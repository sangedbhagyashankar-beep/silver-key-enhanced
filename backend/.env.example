PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/silverkeyhotel
JWT_SECRET=silverkey_jwt_secret_2024
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=silverkey_refresh_2024
JWT_REFRESH_EXPIRES_IN=30d
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# ── Razorpay (leave blank for demo/test mode) ─────────────────────
# Get keys from https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Anthropic AI Chatbot ──────────────────────────────────────────
# Get key from https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Email via Gmail SMTP ──────────────────────────────────────────
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Create an App Password for "Mail" (requires 2FA enabled on your Google account)
# 3. Use your Gmail address as SMTP_USER and the 16-char App Password as SMTP_PASS
# Leave blank to run in demo mode (emails are logged to console, not sent)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM="Silver Key Hotel" <youremail@gmail.com>

# ── Alternative: Brevo / SendGrid / Mailgun ───────────────────────
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your_brevo_login
# SMTP_PASS=your_brevo_smtp_key

# ── Cloudinary (optional, for room image uploads) ─────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── WhatsApp (optional) ───────────────────────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=silverkey_verify
